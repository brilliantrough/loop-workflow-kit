{
  "version": 2,
  "run": {
    "runId": "layer-norm-operator-dsl",
    "workflowName": "operator-dsl-loop",
    "workflowVersion": "2026-07-07",
    "inputArtifact": "artifacts/input.json"
  },
  "sourceStage": {
    "id": "review",
    "attempt": 1,
    "status": "completed",
    "outputArtifact": "artifacts/review-result.json",
    "summaryArtifact": "artifacts/review-notes.md"
  },
  "targetStage": {
    "id": "plan",
    "role": "Revise the plan from review feedback",
    "promptTemplate": "prompts/operator-plan.md",
    "requiredOutputs": [
      "artifacts/plan-output.md",
      "artifacts/plan-summary.json",
      "artifacts/handoff.codegen.md"
    ],
    "stopCondition": "Do not report completion unless every required planning output exists."
  },
  "injection": {
    "sections": [
      {
        "label": "Run Input",
        "artifact": "artifacts/input.json",
        "required": true
      },
      {
        "label": "Fixed Stage System Prompt",
        "promptTemplate": true,
        "required": true
      },
      {
        "label": "Review Result",
        "artifact": "artifacts/review-result.json",
        "required": true
      },
      {
        "label": "Review Notes",
        "artifact": "artifacts/review-notes.md",
        "required": true
      }
    ],
    "renderOrder": [
      "Run Input",
      "Fixed Stage System Prompt",
      "Review Result",
      "Review Notes"
    ]
  },
  "persistence": {
    "mustWrite": [
      "prompt",
      "stdout",
      "stderr",
      "result",
      "selectedArtifacts"
    ],
    "selectedArtifactsRecord": "artifacts/handoff.plan.selected.json"
  },
  "routing": {
    "onSuccess": "codegen",
    "onFailure": "plan"
  }
}
